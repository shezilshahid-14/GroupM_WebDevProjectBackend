# ==============================================================================
# GROUNDVERSE BACKEND - ENVIRONMENT CONFIGURATION
# ==============================================================================
# This file stores the configuration variables for the application backend.
# In a local development environment, rename this file to '.env'.
# DO NOT commit the actual '.env' file containing real secrets to public version control (GitHub).
# ==============================================================================

# ------------------------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Local Development URI:
# MONGO_URI=mongodb://localhost:27017/groundverseDB
#
# Production Cloud URI (MongoDB Atlas):
MONGO_URI=mongodb://admin:securepassword123@cluster0.mongodb.net/groundverseDB

# ------------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ------------------------------------------------------------------------------
# Secret key used for signing JSON Web Tokens (JWT)
JWT_SECRET=gv_prod_secret_998877_xyz
JWT_EXPIRES_IN=1h
